  "keyFeatures": [
    "Bounded memory with fail-fast RSS caps",
    "Zero-manifest loading from raw S3 prefixes",
    "Deterministic replay via pinned manifest_hash",
    "Recovery-oriented distributed lease model",
    "Multi-modal data loaders (text, image, audio, video)",
    "High-availability coordinator with leader fencing",
    "Durable lease log for crash recovery",
    "Dynamic membership with elastic scale-out"
  ],
